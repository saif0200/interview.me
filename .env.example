# Required
DATABASE_URL=postgresql://user:password@localhost:5432/interviewme
DO_MODEL_ACCESS_KEY=your-digitalocean-model-access-key

# Optional: Context enrichment (improves interview quality when a job URL is provided)
SERPER_API_KEY=your-serper-api-key
JINA_API_KEY=your-jina-api-key

# Optional: Model overrides (all default to minimax-m2.5)
# MODEL_PROMPT=minimax-m2.5
# MODEL_INTERVIEW=minimax-m2.5
# MODEL_REPORT=minimax-m2.5
# MODEL_BRIEF=openai-gpt-oss-120b
# LOG_LLM_PAYLOADS=false
